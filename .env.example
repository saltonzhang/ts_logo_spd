# loops
RUN_SCRIPT=sync_match_search_batch.py
BATCH_SIZE=10
MAX_MATCHES=10
POLL_INTERVAL_SECONDS=3600
CONTINUOUS_RUN=true
DRY_RUN=false
PROCESSING_LOOP_DELAY_SECONDS=30

# match-search source mode (for sync_match_search_batch.py)
MATCH_SEARCH_SPORT_IDS=6046,48242
MATCH_SEARCH_POLL_INTERVAL_SECONDS=30
MAX_NEW_PER_CYCLE=0
MATCH_SEARCH_RETRY_FAILED=false

PUT_LOGO_VALUE_FIELD=requested_key

# APIs
NO_LOGO_API_URL=https://ls-sportdata-syncer-api.helix.city/api/v1/competitors/no-logo
PUT_LOGO_API_URL=https://ls-sportdata-syncer-api.helix.city/api/v1/competitors/put-logo

# S3
ATHENA_BASE_URL=https://xp-athena-test1-api.helix.city
ATHENA_ACCESS_KEY=
ATHENA_SECRET_KEY=
ATHENA_REGION_NAME=us-west-2
S3_KEY_PREFIX=sport-img/1/images
S3_BUCKET_NAME=
UPLOAD_JSON_TO_S3=false

# lark
LARK_WEBHOOK_URL=
